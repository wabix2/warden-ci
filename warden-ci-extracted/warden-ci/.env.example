# GitHub App credentials (from https://github.com/settings/apps/your-app)
APP_ID=
# Paste the FULL contents of the downloaded .pem file, including the
# -----BEGIN RSA PRIVATE KEY----- / -----END RSA PRIVATE KEY----- lines.
# server.ts normalizes this at startup (handles escaped \n and writes it to a temp file),
# so most secret-store UIs (Fly, Render, Replit, Railway) work fine with the raw paste.
PRIVATE_KEY=
WEBHOOK_SECRET=

# Gemini API key (aistudio.google.com), used for LLM escalation on uncertain files
GEMINI_API_KEY=

# Host/port the server binds to. 0.0.0.0 + a platform-assigned $PORT is required on
# every free host (Fly/Render/Railway) \u2014 server.ts already defaults these, you shouldn't
# need to set them yourself except for local dev.
HOST=0.0.0.0
PORT=3000
